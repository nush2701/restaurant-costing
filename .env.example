# ---- Database (PostgreSQL — Neon, Supabase, or any Postgres) ---------------
# Pooled connection used by the app at runtime.
#   Neon:     host contains "-pooler"      e.g. ...-pooler.<region>.aws.neon.tech/neondb?sslmode=require
#   Supabase: PgBouncer on port 6543       e.g. ...@HOST:6543/postgres?pgbouncer=true&connection_limit=1
DATABASE_URL="postgresql://USER:PASSWORD@POOLED_HOST/DB?sslmode=require"

# Direct connection (no pooler) used by Prisma for migrations, seeding & restore.
#   Neon:     same host without "-pooler"
#   Supabase: port 5432
DIRECT_URL="postgresql://USER:PASSWORD@DIRECT_HOST/DB?sslmode=require"

# ---- Authentication (NextAuth) --------------------------------------------
# A random secret used to sign session tokens. Generate one with:
#   openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-long-random-secret"

# Base URL of the app. In production set this to your deployed URL.
NEXTAUTH_URL="http://localhost:3000"
