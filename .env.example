# ---- Database (PostgreSQL / Supabase) -------------------------------------
# Pooled connection string used by the app at runtime (Supabase PgBouncer, port 6543).
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true&connection_limit=1"

# Direct connection (no pooler, port 5432) used by Prisma for migrations & seeding.
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# ---- Authentication (NextAuth) --------------------------------------------
# A random secret used to sign session tokens. Generate one with:
#   openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-long-random-secret"

# Base URL of the app. In production set this to your deployed URL.
NEXTAUTH_URL="http://localhost:3000"
